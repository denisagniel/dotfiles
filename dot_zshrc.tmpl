# ~/.zshrc — managed by chezmoi (source: RAND/tools/dotfiles)
# Structured in tiers so it works everywhere:
#   Mac workstation (oh-my-zsh + brew) AND bare servers you SSH into.
# Anything machine-specific is guarded by an existence check, so this
# same file is safe to drop on any host.

# ---------------------------------------------------------------------------
# 1. PATH / package manager (Homebrew if present, either arch)
# ---------------------------------------------------------------------------
if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# User-local bins (installed by the bootstrap script, no root needed)
export PATH="$HOME/.local/bin:$PATH"

# ---------------------------------------------------------------------------
# 2. History (set before oh-my-zsh so its defaults don't clobber these)
# ---------------------------------------------------------------------------
HISTSIZE=50000
SAVEHIST=50000
HISTFILE="$HOME/.zsh_history"
setopt SHARE_HISTORY          # share history across live sessions
setopt HIST_IGNORE_ALL_DUPS   # drop older duplicate of a repeated command
setopt HIST_IGNORE_SPACE      # a leading space keeps a command out of history
setopt HIST_FIND_NO_DUPS      # don't show dupes when searching
setopt HIST_REDUCE_BLANKS
setopt EXTENDED_HISTORY       # record timestamps

# ---------------------------------------------------------------------------
# 3. Prompt + plugins
#    Prefer oh-my-zsh when it's installed (your Mac); otherwise fall back to a
#    lightweight pure-zsh setup so servers still feel familiar.
# ---------------------------------------------------------------------------
export ZSH="$HOME/.oh-my-zsh"

if [[ -d "$ZSH" ]]; then
    # ---- full oh-my-zsh path (workstation) ----
    # We use starship for the prompt, so the OMZ theme is intentionally empty.
    ZSH_THEME=""
    zstyle ':omz:update' mode auto
    COMPLETION_WAITING_DOTS="true"
    plugins=(
        git
        brew
        macos
        colored-man-pages
        command-not-found
    )
    source "$ZSH/oh-my-zsh.sh"
else
    # ---- minimal fallback (bare server) ----
    autoload -Uz compinit && compinit -u
    autoload -Uz colors && colors
    # A few of the git aliases you rely on from the OMZ git plugin:
    alias g='git'
    alias gst='git status'
    alias gco='git checkout'
    alias gcb='git checkout -b'
    alias gaa='git add --all'
    alias gcmsg='git commit -m'
    alias gp='git push'
    alias gl='git pull'
fi

# Case-insensitive / partial-word completion (applies in both paths)
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*'
zstyle ':completion:*' menu no   # fzf-tab replaces the menu; if it's absent, plain menu still works

# ---------------------------------------------------------------------------
# 3b. fzf-tab — fuzzy interactive tab completion (must load AFTER compinit and
#     the zstyles above, but BEFORE the widget-wrapping plugins in section 4).
#     No-op if the clone isn't present (fresh machine before chezmoi apply).
# ---------------------------------------------------------------------------
if [[ -f "$HOME/.local/share/fzf-tab/fzf-tab.plugin.zsh" ]]; then
    source "$HOME/.local/share/fzf-tab/fzf-tab.plugin.zsh"
    # Group completions need a descriptions format string to be set.
    zstyle ':completion:*:descriptions' format '[%d]'
    # Directory preview on `cd <TAB>` — eza if present, else ls.
    if command -v eza >/dev/null 2>&1; then
        zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always --icons $realpath 2>/dev/null'
    else
        zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls -1 $realpath 2>/dev/null'
    fi
    # Preview file contents on kill/env/other selections where a path makes sense.
    zstyle ':fzf-tab:*' switch-group ',' '.'   # ,/. to move between completion groups
fi

# ---------------------------------------------------------------------------
# 4. Plugins that live outside oh-my-zsh (brew OR ~/.local/share clone).
#    autosuggestions first, syntax-highlighting LAST (it must be last).
# ---------------------------------------------------------------------------
for _p in \
    /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
    /usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
    "$HOME/.local/share/zsh-autosuggestions/zsh-autosuggestions.zsh"; do
    [[ -f "$_p" ]] && { source "$_p"; break; }
done

# ---------------------------------------------------------------------------
# 5. Modern CLI tool inits (all guarded — no-op if the tool isn't installed)
# ---------------------------------------------------------------------------
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"
command -v zoxide   >/dev/null 2>&1 && eval "$(zoxide init zsh)"
command -v fzf      >/dev/null 2>&1 && source <(fzf --zsh 2>/dev/null)

# atuin — SQLite-backed, cross-machine shell history on Ctrl-R.
# Init AFTER fzf so atuin wins the Ctrl-R binding. --disable-up-arrow keeps the
# familiar up-arrow behavior (per-session prefix search) and only rebinds Ctrl-R.
command -v atuin    >/dev/null 2>&1 && eval "$(atuin init zsh --disable-up-arrow)"

# syntax-highlighting must be sourced LAST of the plugins.
for _p in \
    /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
    /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
    "$HOME/.local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"; do
    [[ -f "$_p" ]] && { source "$_p"; break; }
done

# Fallback prompt if starship isn't available (keeps a git-aware, clean prompt)
if ! command -v starship >/dev/null 2>&1; then
    autoload -Uz vcs_info
    zstyle ':vcs_info:git:*' formats ' (%b)'
    precmd_vcs() { vcs_info }
    autoload -Uz add-zsh-hook && add-zsh-hook precmd precmd_vcs
    setopt PROMPT_SUBST
    PROMPT='%F{cyan}%n@%m%f %F{blue}%~%f%F{yellow}${vcs_info_msg_0_}%f
%(?.%F{green}.%F{red})❯%f '
fi

# ---------------------------------------------------------------------------
# 6. Editor
# ---------------------------------------------------------------------------
if command -v nvim >/dev/null 2>&1; then
    export EDITOR='nvim' VISUAL='nvim'
else
    export EDITOR='vim' VISUAL='vim'
fi

# ---------------------------------------------------------------------------
# 7. Personal aliases / functions
# ---------------------------------------------------------------------------
[[ -f "$HOME/.zsh_custom" ]] && source "$HOME/.zsh_custom"

# ---------------------------------------------------------------------------
# 8. Secrets fallback (gitignored, machine-local). Present only where you've
#    created it by hand; primary secret storage is ~/.aws + chezmoi templates.
# ---------------------------------------------------------------------------
[[ -f "$HOME/.config/dotfiles/secrets.zsh" ]] && source "$HOME/.config/dotfiles/secrets.zsh"

# ---------------------------------------------------------------------------
# 9. Claude Code / Bedrock (env-only settings; credentials come from ~/.aws)
# ---------------------------------------------------------------------------
export CLAUDE_CODE_USE_BEDROCK=1
export AWS_REGION="${AWS_REGION:-us-west-2}"
export ANTHROPIC_MODEL=us.anthropic.claude-opus-4-8
export ANTHROPIC_SMALL_FAST_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ---------------------------------------------------------------------------
# 10. RAND-specific: CA bundles for sandboxed tooling.
#     Only exported when the bundle actually exists on this machine, so this
#     block is a harmless no-op on servers and personal machines.
# ---------------------------------------------------------------------------
if [[ -f "$HOME/.config/sandbox-exec/ca-bundle.pem" ]]; then
    export SAFEHOUSE_CA_BUNDLE="$HOME/.config/sandbox-exec/ca-bundle.pem"
    export REQUESTS_CA_BUNDLE="$SAFEHOUSE_CA_BUNDLE"
    export CURL_CA_BUNDLE="$SAFEHOUSE_CA_BUNDLE"
    export SSL_CERT_FILE="$SAFEHOUSE_CA_BUNDLE"
    export NODE_EXTRA_CA_CERTS="$SAFEHOUSE_CA_BUNDLE"
fi
if [[ -f /Users/Shared/RANDCerts/RAND_PKI_Root.pem ]]; then
    export AWS_CA_BUNDLE="/Users/Shared/RANDCerts/RAND_PKI_Root.pem"
fi

# Quarto shipped inside RStudio.app (Mac only)
if [[ -d "/Applications/RStudio.app/Contents/Resources/app/quarto/bin" ]]; then
    export PATH="/Applications/RStudio.app/Contents/Resources/app/quarto/bin:$PATH"
fi

# ---------------------------------------------------------------------------
# 11. agent-safehouse (RAND workstation only; guarded so it's portable)
# ---------------------------------------------------------------------------
_safehouse="/Users/dagniel/RAND/tools/agent-safehouse-setup/shell/safehouse.zsh"
[[ -f "$_safehouse" ]] && source "$_safehouse"
unset _safehouse _p
