#!/usr/bin/env bash
# Runs ONCE per machine on first `chezmoi apply` (re-runs only if this file
# changes). Installs the CLI tools the dotfiles want, using whatever package
# manager is available. Everything is best-effort and non-fatal.
set -uo pipefail

log() { printf '\033[1;34m[bootstrap]\033[0m %s\n' "$*"; }

# ---------------------------------------------------------------------------
# macOS + Homebrew
# ---------------------------------------------------------------------------
if command -v brew >/dev/null 2>&1; then
    log "Homebrew detected — installing CLI tools"
    brew install --quiet \
        starship fzf zoxide eza bat ripgrep fd git \
        zsh-autosuggestions zsh-syntax-highlighting \
        atuin radian 2>/dev/null || true

# ---------------------------------------------------------------------------
# Debian/Ubuntu servers with apt + sudo
# ---------------------------------------------------------------------------
elif command -v apt-get >/dev/null 2>&1 && command -v sudo >/dev/null 2>&1; then
    log "apt detected — installing what's packaged"
    sudo apt-get update -qq || true
    # Package names vary; fd is fd-find, bat is batcat on Debian.
    sudo apt-get install -y -qq zsh git fzf ripgrep fd-find bat zoxide 2>/dev/null || true
    # starship + eza aren't in older apt repos — grab starship's installer.
    if ! command -v starship >/dev/null 2>&1; then
        curl -fsSL https://starship.rs/install.sh | sh -s -- --yes --bin-dir "$HOME/.local/bin" || true
    fi

# ---------------------------------------------------------------------------
# Locked-down server: no root. Install starship to ~/.local/bin only.
# ---------------------------------------------------------------------------
else
    log "No usable package manager with privileges — installing starship to ~/.local/bin"
    mkdir -p "$HOME/.local/bin"
    if ! command -v starship >/dev/null 2>&1; then
        curl -fsSL https://starship.rs/install.sh | sh -s -- --yes --bin-dir "$HOME/.local/bin" || true
    fi
    log "zsh plugins will be provided via chezmoi externals (~/.local/share)"
fi

# ---------------------------------------------------------------------------
# Cross-platform extras (non-brew hosts). fzf-tab is clone-only (chezmoi
# external), but it's useless without the fzf binary — and the no-root branch
# above never installs it. atuin + radian also need their own routes.
# All best-effort and non-fatal.
# ---------------------------------------------------------------------------
if ! command -v fzf >/dev/null 2>&1; then
    # Official installer: git clone + a binary in ~/.fzf/bin, no root needed.
    log "installing fzf (required by fzf-tab)"
    if git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf" 2>/dev/null; then
        # --bin fetches the prebuilt binary into ~/.fzf/bin (on PATH? see below).
        "$HOME/.fzf/install" --bin >/dev/null 2>&1 || true
        # Symlink into ~/.local/bin so it's on the PATH .zshrc already exports.
        mkdir -p "$HOME/.local/bin"
        [[ -x "$HOME/.fzf/bin/fzf" ]] && ln -sf "$HOME/.fzf/bin/fzf" "$HOME/.local/bin/fzf"
    fi
    command -v fzf >/dev/null 2>&1 || [[ -x "$HOME/.local/bin/fzf" ]] \
        || log "fzf install failed — fzf-tab will stay disabled until fzf is on PATH"
fi

if ! command -v atuin >/dev/null 2>&1; then
    log "installing atuin (cross-machine shell history)"
    # Official installer; drops binary into ~/.local/bin or ~/.atuin/bin.
    curl -fsSL https://setup.atuin.sh | sh || true
fi

if ! command -v radian >/dev/null 2>&1; then
    # radian is a Python package. Prefer pipx (isolated, puts a binary on PATH);
    # else pip --user. Surface errors instead of swallowing them, so a silent
    # failure doesn't masquerade as success.
    if command -v pipx >/dev/null 2>&1; then
        log "installing radian via pipx"
        pipx install radian || log "radian: pipx install failed (see above)"
    elif command -v python3 >/dev/null 2>&1; then
        # Use `python3 -m pip`, NOT the pip3 shim — on some RHEL boxes the
        # /usr/local/bin/pip3 wrapper is broken (No module named pip._internal)
        # while the module under a real python works. ensurepip repairs a
        # missing user pip. --user lands radian in ~/.local/bin (already PATH).
        log "installing radian via python3 -m pip --user"
        python3 -m pip --version >/dev/null 2>&1 || python3 -m ensurepip --user >/dev/null 2>&1 || true
        python3 -m pip install --user radian || log "radian: pip install failed (see above)"
    else
        log "radian: no python3/pipx found — skipping"
    fi
    command -v radian >/dev/null 2>&1 \
        || log "radian not on PATH after install — check ~/.local/bin, or install pipx"
fi

log "done. Restart your shell or run: exec zsh"
